# ─── Database ─────────────────────────────────────────────────────────────────
# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@localhost:3306/bizdoc_consult

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret

# OAuth server base URL (your authentication provider)
OAUTH_SERVER_URL=https://your-oauth-server.com

# Your application ID registered with the OAuth provider
VITE_APP_ID=your-app-id

# The public-facing OAuth login URL (used by the frontend to redirect users)
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com

# Open ID of the platform owner/founder account (used for founder-only access checks)
OWNER_OPEN_ID=founder-open-id

# ─── Anthropic AI (Claude) ────────────────────────────────────────────────────
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Forge API (legacy — no longer used for AI) ───────────────────────────────
BUILT_IN_FORGE_API_KEY=your-forge-api-key
BUILT_IN_FORGE_API_URL=https://forge.butterfly-effect.dev

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (defaults to 3000 if not set)
PORT=3000

# Node environment
NODE_ENV=development
